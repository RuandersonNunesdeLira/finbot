# OpenAI
OPENAI_API_KEY=sk-your-key-here

#Brapi
BRAPI_API_KEY=

# WAHA (generate with: docker run --rm -v "$(pwd)":/app/env devlikeapro/waha init-waha /app/env)
WAHA_API_URL=http://waha:3000
WAHA_SESSION_NAME=default
WAHA_API_KEY=your-api-key-here
WAHA_DASHBOARD_USERNAME=admin
WAHA_DASHBOARD_PASSWORD=your-dashboard-password-here

# ChromaDB
CHROMA_HOST=chromadb
CHROMA_PORT=8000

# Backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8080
